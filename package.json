  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && rm -rf public && mkdir public && cp -r client/dist/* public/",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
